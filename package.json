{
  "name": "case-clicker",
  "version": "1.2.0",
  "private": true,
  "description": "CS:GO Case Simulator - N Games Crew Edition",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "node server/index.js",
    "postinstall": "cd client && npm install && npm run build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --win dir"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "socket.io": "^4.7.4",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ngames.caseclicker",
    "productName": "Case Clicker",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "electron/icon.ico"
    },
    "portable": {
      "artifactName": "CaseClicker.exe"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
